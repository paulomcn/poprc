# Banco de desenvolvimento
DB_URL=jdbc:postgresql://localhost:5432/poprc_dev
DB_USERNAME=postgres
DB_PASSWORD=altere_esta_senha

# Segurança e URLs
APP_SECURITY_ENABLED=false
DEV_LOGIN_ENABLED=true
REAUTHENTICATION_MINUTES=5
FRONTEND_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:[*],http://127.0.0.1:[*],http://192.168.*:[*],http://10.*:[*]

# Antes de piloto, homologacao com usuarios reais ou publicacao:
# APP_SECURITY_ENABLED=true
# DEV_LOGIN_ENABLED=false
